/*
 * conf/modules.config -- per-process ext.args, publishDir, and the OOM retry policy.
 *
 * Non-mandatory DeepSAP flags are composed here from top-level params, never hardcoded in
 * the module script, so they can be changed without touching pipeline code.
 */

process {

    // NOTE: there is deliberately no `withName: 'STAGE_CTMP'` block. STAGE_CTMP and
    // PREPARE_REFERENCE manage internal scratch state rather than producing pipeline
    // results, so neither needs a publishDir -- and an EMPTY selector block is not a
    // harmless placeholder: Nextflow parses `withName: 'X' { }` as an assignment to an
    // unknown attribute and aborts the run with
    //     Unknown config attribute `process.withName:STAGE_CTMP`
    // before a single task starts. (Observed, not theorised: it is what this config did on
    // its first real invocation.)

    withName: 'DEEPSAP_TSJS' {
        ext.args = [
            (params.score_reads && params.n_reads) ? "--score_reads --n_reads ${params.n_reads}" : '',
            (params.fp16 == true)  ? '--fp16'    : '',
            (params.fp16 == false) ? '--no-fp16' : '',
            (params.test)          ? '--test'    : ''
        ].findAll { arg -> arg }.join(' ')

        // Retry ladder for a POSITIVELY IDENTIFIED CUDA-OOM signature only (the module
        // script greps its own captured log and exits 137 specifically for that case).
        // Never retries on a bare non-zero exit -- deepsap-cluster-feasibility's own
        // history is explicit that retrying an unrelated failure as though it were a
        // capacity problem just burns a second GPU allocation on the same bug.
        errorStrategy = { task.exitStatus == 137 && task.attempt <= 3 ? 'retry' : 'finish' }
        maxRetries    = 2

        // Module outputs are declared as outdir/<prefix>... (outdir/ is DeepSAP's own --out
        // target, kept separate from the task's input-staging area -- see the module
        // comments). saveAs strips that outdir/ prefix so published files land directly
        // under <outdir>/deepsap/<sample>/ rather than <outdir>/deepsap/<sample>/outdir/ --
        // confirmed by an actual -stub-run that without this strip, Nextflow preserves the
        // outdir/ path component in the published tree.
        publishDir = [
            path: { "${params.outdir}/deepsap/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename.replaceFirst(/^outdir\//, '') }
        ]
    }
}
