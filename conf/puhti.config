/*
 * conf/puhti.config -- CSC Puhti. One concrete instantiation of conf/slurm.config.
 *
 * These are MEASURED, not defaults: private_projects/deepsap-cluster-feasibility ran this
 * container on `gpu` with --gres=gpu:v100:1 under account project_2009297, and this pipeline
 * itself ran there on 2026-07-19 (4 tasks, 4m01s). The `small` partition is verified against
 * sinfo: fmi gpu test large small fmitest gputest hugemem longrun interactive hugemem_longrun.
 *
 * Puhti's `singularity` is a symlink to apptainer 1.3.6, so -profile puhti selects apptainer
 * explicitly -- there is no real SingularityCE here to select.
 *
 * Use this file as the template for another site: copy it, change the four params, and point
 * deepsap_sif at your own SIF.
 */

includeConfig 'slurm.config'

params {
    account       = 'project_2009297'
    gpu_partition = 'gpu'
    cpu_partition = 'small'
    gpu_gres      = 'gpu:v100:1'

    deepsap_sif   = '/scratch/project_2009297/deepsap-feasibility/images/deepsap.sif'
}

apptainer {
    enabled    = true
    autoMounts = true
}

singularity.enabled = false
