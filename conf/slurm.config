/*
 * conf/slurm.config -- GENERIC SLURM profile, no site baked in.
 *
 * conf/puhti.config is one concrete instantiation of this file. Use this one directly on any
 * other SLURM cluster:
 *
 *   nextflow run main.nf -profile slurm,singularity \
 *       --account my_project --gpu_partition gpu --cpu_partition small \
 *       --gpu_gres 'gpu:a100:1' --deepsap_sif /path/to/deepsap.sif --ctmp /scratch/me/ctmp ...
 *
 * Every site-specific value is a null-defaulted param rather than a guess. A flag is emitted
 * ONLY when its param is set: clusters differ on whether --account exists at all, and on
 * whether GPUs come from --gres, from a partition alone, or from --gpus. Emitting
 * `--account=null` would fail sbatch on every one of them.
 */

params {
    account       = null      // --account=<x>; leave null on clusters with no accounting
    gpu_partition = null      // partition for the GPU scoring task
    cpu_partition = null      // partition for the light CPU tasks; falls back to gpu_partition
    gpu_gres      = 'gpu:1'   // --gres=<x>; set null if this cluster allocates GPUs another way
    gpu_extra     = null      // any additional sbatch flags for the GPU task, verbatim

    // Environment module(s) to load on the COMPUTE NODE before anything runs, e.g.
    // 'apptainer' or 'apptainer/1.3.6'. Colon-separate for several ('apptainer:cuda').
    //
    // Needed because Nextflow invokes `apptainer exec` from inside the generated .command.run,
    // which runs on the compute node -- and on many clusters apptainer is NOT on the default
    // compute-node PATH even when it is on the login node's. That failure looks like
    // "apptainer: command not found" from a job that submitted perfectly. Puhti happens not to
    // need this (apptainer is at /usr/bin), which is exactly why it is easy to miss when
    // porting off it.
    container_module = null
}

// Treat a param as unset when it is null/empty OR when it is the literal STRING 'null',
// 'none' or 'false'. That last part is not pedantry: `--gpu_gres null` on the command line
// arrives as the four-character string "null", which is TRUTHY in Groovy, so without this the
// most natural way to ask for "no --gres" would emit `--gres=null` and every job would be
// rejected by sbatch. (`--gpu_gres false` is caught earlier by the schema, which types it as
// boolean; `--gpu_gres ''` was always fine. This closes the remaining spelling.)
def unsetish = { v -> !v || v.toString().trim().toLowerCase() in ['null', 'none', 'false'] }

process {
    executor = 'slurm'

    withLabel: process_gpu {
        // RESTATED from the same params as conf/base.config, and that is not redundant.
        // Declaring the identical selector string in two config files makes Nextflow REPLACE
        // the earlier block, not merge into it. Before these three lines existed, this block
        // deleted base.config's cpus/memory/time and every SLURM run of DEEPSAP_TSJS got the
        // top-level fallback -- 1 CPU and 4 GB -- while the config said 8 and 64 GB. It
        // survived the whole P. falciparum campaign unnoticed (23 MB genome, 25 s) and killed
        // the first mouse job at once. Keep both blocks sourced from params so that whichever
        // one wins carries identical values.
        cpus           = params.gpu_cpus
        memory         = params.gpu_memory
        time           = params.gpu_time

        queue          = { unsetish(params.gpu_partition) ? null : params.gpu_partition }
        clusterOptions = {
            [ unsetish(params.account)   ? '' : "--account=${params.account}",
              unsetish(params.gpu_gres)  ? '' : "--gres=${params.gpu_gres}",
              unsetish(params.gpu_extra) ? '' : "${params.gpu_extra}"
            ].findAll { opt -> opt }.join(' ')
        }
    }

    // The light processes (STAGE_CTMP, PREPARE_REFERENCE) must not sit in a GPU queue if the
    // cluster has a cheaper one -- but falling back to gpu_partition is better than falling
    // back to nothing, since a null queue lands wherever SLURM's default is.
    withLabel: 'process_single|process_low|process_medium|process_high' {
        queue = {
            def q = unsetish(params.cpu_partition) ? params.gpu_partition : params.cpu_partition
            unsetish(q) ? null : q
        }
        clusterOptions = { unsetish(params.account) ? '' : "--account=${params.account}" }
    }
}

// Set the `module` directive ONLY when a module was actually requested.
//
// It must NOT be expressed as `process.module = { ... null ... }` inside the process block:
// a null returned from that closure makes Nextflow die with
//     Cannot invoke "java.lang.CharSequence.toString()" because "self" is null
// before any task runs -- which is what the first version of this did, breaking every SLURM
// run that did not set --container_module. Conditionally assigning the directive at
// config-parse time sidesteps the null entirely.
//
// Applies to EVERY process: STAGE_CTMP, PREPARE_REFERENCE and DEEPSAP_TSJS all launch a
// container, so all three need the engine on PATH.
if (params.container_module && !(params.container_module.toString().trim().toLowerCase() in ['null', 'none', 'false'])) {
    process.module = params.container_module
}
