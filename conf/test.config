/*
 * conf/test.config -- cheap CI / dry-run profile.
 *
 * NOTE FOR ANYONE OUTSIDE CSC: every path in here is a CSC Puhti scratch path under a
 * specific project allocation. They will not exist for you. This profile is kept as-is
 * because its value is being a regression check with a KNOWN-GOOD md5 (see below), which is
 * only meaningful against those exact files. Override --input/--fasta/--gtf to point at your
 * own data, or ignore this profile entirely and follow README "Recommended first run".
 *
 * Sets params.test = true, which the module maps to DeepSAP's own --test flag ("don't
 * perform prediction" -- verified CLI flag, not invented). Combine with `puhti` to route
 * the GPU task at `gputest` (15 min limit, near-zero queue, per this pipeline's own task
 * brief) instead of `gpu`: `-profile puhti,test`.
 *
 * fasta/gtf point at the malaria reference already fetched and verified in
 * deepsap-cluster-feasibility (scripts/fetch_testdata.sh) -- real, existing paths on Puhti.
 *
 * params.input points at the GSNAP BAM from canary 35519462. That BAM is the useful default
 * because its TSJS output is KNOWN byte-for-byte (job 35520334, reproduced again through this
 * pipeline on 2026-07-19): junctions.tsv md5 2c4640e182cb9399405fbf5a037749e2, probs.npy md5
 * a82c0fb6c31390789b33bee92b2c00de. So this profile is not merely a smoke test -- it is a
 * regression check with an expected answer. Note the md5s only hold with test=false; --test
 * skips prediction, so flip `test` off when using it that way.
 *
 * For a STAR-shaped input instead, see tests/make_star_bam.sbatch, which builds
 * star_test/star_Aligned.sortedByCoord.out.bam (coordinate-sorted, 796 secondary alignments).
 */

params {
    test   = true
    fasta  = '/scratch/project_2009297/deepsap-feasibility/testdata/malaria_short_pe/Plasmodium_falciparum.ASM276v2.dna.toplevel.fa'
    gtf    = '/scratch/project_2009297/deepsap-feasibility/testdata/malaria_short_pe/Plasmodium_falciparum.ASM276v2.60.gtf'
    input  = '/scratch/project_2009297/deepsap-feasibility/outputdir/run_35519462/test_run_10K_default_gsnap.bam'
    outdir = './results-test'

    puhti_gpu_partition = 'gputest' // only takes effect when combined with -profile puhti
}

process {
    withLabel: process_gpu {
        time = 15.min
    }
}
