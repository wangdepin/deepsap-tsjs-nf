/*
 * conf/base.config -- resource tiers by label.
 *
 * process_gpu's cpus/memory/time are not guessed: they are
 * private_projects/deepsap-cluster-feasibility/scripts/04_end_to_end.sbatch's
 * #SBATCH --cpus-per-task=8 --mem=64G --time=02:00:00, the settings that were actually
 * used to run this exact container on a Puhti V100 32GB. Carried over verbatim.
 */

process {
    cpus            = 1
    memory          = 4.GB
    time            = 1.h
    errorStrategy   = 'finish'

    withLabel: process_single {
        cpus   = 1
        memory = 4.GB
        time   = 30.min
    }
    withLabel: process_low {
        cpus   = 2
        memory = 8.GB
        time   = 1.h
    }
    withLabel: process_medium {
        cpus   = 4
        memory = 16.GB
        time   = 2.h
    }
    withLabel: process_high {
        cpus   = 8
        memory = 32.GB
        time   = 4.h
    }
    // Measured, not guessed -- see comment above. errorStrategy/maxRetries for the OOM
    // ladder live in conf/modules.config (withName: 'DEEPSAP_TSJS'), scoped to that one
    // process rather than every process_gpu-labelled one, since the retry is conditioned on
    // a specific CUDA-OOM log signature this module produces itself.
    //
    // These come from params, and conf/slurm.config's `withLabel: process_gpu` block RESTATES
    // all three from the same params. That duplication is deliberate and load-bearing:
    // Nextflow REPLACES a selector block when a later config file declares the IDENTICAL
    // selector string, rather than merging key by key. slurm.config used to declare
    // `withLabel: process_gpu { queue; clusterOptions }` and thereby silently deleted the
    // cpus/memory/time set here, so every SLURM run fell back to the top-level defaults
    // (cpus 1, memory 4 GB) -- confirmed by `nextflow config -flat`, which listed only queue
    // and clusterOptions under process_gpu while the other four labels kept their resources.
    // The other four survived only because slurm.config addresses them through a COMBINED
    // selector ('process_single|process_low|...'), a different string that does not collide.
    //
    // This went unnoticed through the entire P. falciparum campaign, including the
    // from-scratch validation, because a 23 MB genome fits in 4 GB and finishes in 25 s
    // single-threaded. The first mouse run died instantly: SLURM killed it at 4.6 GB against
    // a 4 GiB cap it should never have had. Sourcing both blocks from params means a future
    // collision is harmless -- whichever block wins carries the same numbers.
    withLabel: process_gpu {
        cpus   = params.gpu_cpus
        memory = params.gpu_memory
        time   = params.gpu_time
    }
}
