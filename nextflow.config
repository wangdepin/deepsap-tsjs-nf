/*
 * deepsap-tsjs-nf -- central pipeline configuration.
 *
 * Container digest, wrapper behaviour, /tmp staging requirements, output naming and
 * required-flag list are all measured facts carried over from private_projects/
 * deepsap-cluster-feasibility. See README.md for the full contract and for what is a
 * judgement call vs. what is unverified.
 */

manifest {
    name            = 'deepsap-tsjs-nf'
    author          = 'RACA workspace'
    description     = 'Score an existing BAM with DeepSAP TSJS only (no GSNAP alignment)'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.10.0'
    version         = '0.1.0'
}

// nf-schema handles --help and validateParameters(). Pinned to the version resolved during
// this pipeline's own `-stub-run` smoke test (see README) -- nf-schema itself refuses to
// run unpinned ("you just entered the danger zone") and requires draft 2020-12 schemas,
// which nextflow_schema.json / assets/schema_input.json use.
plugins {
    id 'nf-schema@2.7.3'
}

params {
    // ---- input / output ----
    input              = null   // samplesheet CSV ('sample,bam') OR a glob of BAM/SAM files
    fasta              = null   // reference FASTA, UNCOMPRESSED; must share contig names with
                                 // every BAM (GENCODE 'chr1' vs Ensembl '1' is the classic
                                 // STAR-BAM mismatch -- the scoring module preflights it)
    fai                = null   // optional <fasta>.fai. When null the pipeline uses an
                                 // existing sibling index if there is one, else builds it
                                 // once via PREPARE_REFERENCE. Never built per sample.
    gtf                = null   // reference GTF matching the FASTA
    outdir             = './results'
    publish_dir_mode   = 'copy'

    // ---- container / cluster runtime ----
    //
    // Defaults to the NGC image pinned BY DIGEST, so nothing has to be downloaded by hand:
    // Nextflow hands this to apptainer, which pulls and converts it on first use and caches
    // the result. Anonymous pull is confirmed working (HTTP 200 on the digest manifest,
    // 83 layers, ~19.3 GB compressed -> ~12 GB SIF); no NGC login or API key is needed.
    //
    // Pinned by digest rather than :latest on purpose. Everything this pipeline asserts about
    // DeepSAP -- the wrapper's injected flags, the /tmp/83 checkpoint and its exact byte
    // count, the extensionless output name, the js/jt/nj tags -- was measured against THIS
    // image. A floating tag would let NVIDIA change any of that silently under a pipeline
    // that would keep exiting 0.
    //
    // Override with a local .sif path to skip the pull entirely (recommended on clusters
    // whose compute nodes have no route to the internet -- see README "Getting the image").
    deepsap_sif        = 'docker://nvcr.io/nvidia/clara/clara-parabricks-deepsap@sha256:d437752a03761b8c73aab1962e1aed877c58f99844f7b4856b676a2257becebf'

    // NOTE: there is deliberately no `container_cachedir` param. Where the ~12 GB converted
    // SIF is cached is set with the standard environment variable
    //     export NXF_APPTAINER_CACHEDIR=/scratch/<proj>/sifcache
    // (or NXF_SINGULARITY_CACHEDIR). A param was tried and removed: expressing it as a
    // top-level `if (params.x) { apptainer.cacheDir = ... }` only sees values supplied on the
    // command line, because `-c` config files are merged AFTER this file is parsed -- so the
    // same param would silently work one way of invoking it and not another. The env var has
    // no such asymmetry. Point it at a persistent SHARED path, never $HOME (quota).
    ctmp               = null   // persistent HOST dir pre-staged (or to be staged) with the
                                 // image's own /tmp/83 checkpoint tree -- see modules/local/
                                 // stage_ctmp. REQUIRED: no cluster-agnostic default exists.

    // ---- GPU task resources ----
    //
    // Exposed as params so they can be raised for a large genome without editing a config
    // file, and so conf/base.config and conf/slurm.config can BOTH state them from one
    // source. See the comment in base.config for why both must state them.
    //
    // The defaults are the measured P. falciparum settings carried over from
    // deepsap-cluster-feasibility (--cpus-per-task=8 --mem=64G --time=02:00:00). They are NOT
    // yet validated at mammalian scale: mm10 + GENCODE vM25 is a 2.8 GB FASTA and an 888 MB
    // GTF, against 23 MB and 4 MB for the malaria test set. Raise --gpu_memory if a run is
    // killed by the scheduler (exit 137 with an 'exceeded memory limit' line in .command.log,
    // which is the SCHEDULER killing the task and is a different failure from the CUDA-OOM
    // signature that drives the retry ladder in conf/modules.config).
    gpu_cpus           = 8
    gpu_memory         = '64.GB'
    gpu_time           = '2.h'

    // ---- DeepSAP CLI pass-through (only what --sam mode needs; see README for the full
    // verified flag list and what is deliberately NOT exposed here) ----
    batch              = 32     // wrapper's own default; overridden per-attempt on OOM retry
    set_size           = null
    threads            = null   // null => use task.cpus
    score_reads        = false
    n_reads            = null
    fp16               = null   // null => don't pass either --fp16 or --no-fp16
    test               = false  // --test: "don't perform prediction" (cheap CI/dry-run)

    help               = false
}

// Always-loaded config: resource labels + per-module ext.args/publishDir.
includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

// Default container engine, set OUTSIDE profiles so that every profile combination has one.
// If this lived only in `standard`, then `-profile slurm` alone would silently run with no
// container at all -- Nextflow does not apply `standard` once any -profile is given.
apptainer {
    enabled     = true
    autoMounts  = true
    // Nextflow's default pullTimeout is 20 minutes. Converting ~19.3 GB of layers into a SIF
    // over a shared cluster link does not reliably fit in that, and when it does not, the
    // failure is a timeout partway through rather than anything that names the real cause.
    pullTimeout = '3h'
}

profiles {

    // ---- container engines (pick one; apptainer is the default above) ----

    apptainer {
        apptainer.enabled      = true
        apptainer.autoMounts   = true
        singularity.enabled    = false
    }

    // SingularityCE. The flags this pipeline needs are all supported by it: --nv, --cleanenv,
    // --home src:dst, --writable-tmpfs, --bind, --pwd, and crucially `--no-mount tmp`, which
    // STAGE_CTMP cannot work without and which SingularityCE has had since 3.7.0 (2020).
    // STAGE_CTMP's beforeScript checks for it and fails with an actionable message rather
    // than letting the container launch die cryptically.
    //
    // NOT VERIFIED AGAINST REAL SingularityCE: the only cluster available here (Puhti) ships
    // `singularity` as a symlink to apptainer 1.3.6, so exercising this profile there tests
    // the Nextflow wiring and nothing about Sylabs' implementation. Treat the first run on a
    // genuine SingularityCE site as the real test -- see README "Running elsewhere".
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        apptainer.enabled      = false
    }

    // ---- executors ----

    standard {
        process.executor = 'local'
    }

    // Generic SLURM: supply --account / --gpu_partition / --cpu_partition / --gpu_gres.
    slurm {
        includeConfig 'conf/slurm.config'
    }

    // ---- sites ----

    puhti {
        includeConfig 'conf/puhti.config'
    }

    test {
        includeConfig 'conf/test.config'
    }
}
